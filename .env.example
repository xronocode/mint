# MINT Runtime Configuration
# Copy this file to .env and fill in your values

# LLM Endpoint (OpenAI-compatible)
LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
LLM_MODEL=glm-5
MINT_MODEL_TIER=frontier
MINT_SEVERITY_MODE=audit

# Optional: API key (leave empty for local models without auth)
# LLM_API_KEY=

# MINT_SANDBOX_TIMEOUT=30
# MINT_ROOT=.
# MINT_RULES_DIR=rules
# MINT_SKILLS_DIR=skills
# MINT_TEMPLATES_DIR=templates
# MINT_TOKENS_DIR=tokens

# Default is python; set js to keep the legacy Node.js sandbox path runnable in Phase-6.
# MINT_ENGINE=js
