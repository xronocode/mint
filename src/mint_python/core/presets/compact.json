{
  "$schema": "https://mint.dev/schema/style-preset-1.0.json",
  "name": "compact",
  "version": "1.0",
  "description": "Tight spacing for one-page memos; smaller fonts, reduced spacing_after",
  "color_palette": {
    "primary":    "#0F4C81",
    "secondary":  "#5B8DBE",
    "accent":     "#FFB400",
    "text":       "#1A1A1A",
    "text_muted": "#6E6E6E",
    "background": "#FFFFFF",
    "border":     "#D4D4D4"
  },
  "typography": {
    "heading1": {
      "font": "Inter",
      "size_pt": 18,
      "color": "@primary",
      "bold": true,
      "alignment": "left",
      "spacing_before_pt": 8,
      "spacing_after_pt": 4,
      "line_height": 1.2,
      "keep_with_next": true
    },
    "heading2": {
      "font": "Inter",
      "size_pt": 14,
      "color": "@primary",
      "bold": true,
      "alignment": "left",
      "spacing_before_pt": 6,
      "spacing_after_pt": 3,
      "line_height": 1.25,
      "keep_with_next": true
    },
    "heading3": {
      "font": "Inter",
      "size_pt": 12,
      "color": "@primary",
      "bold": true,
      "alignment": "left",
      "spacing_before_pt": 4,
      "spacing_after_pt": 2,
      "line_height": 1.3,
      "keep_with_next": true
    },
    "body": {
      "font": "Inter",
      "size_pt": 10,
      "color": "@text",
      "alignment": "left",
      "spacing_before_pt": 0,
      "spacing_after_pt": 3,
      "line_height": 1.3
    },
    "table_header": {
      "font": "Inter",
      "size_pt": 10,
      "color": "@background",
      "bold": true,
      "alignment": "left",
      "spacing_before_pt": 0,
      "spacing_after_pt": 0,
      "line_height": 1.15
    },
    "caption": {
      "font": "Inter",
      "size_pt": 8,
      "color": "@text_muted",
      "italic": true,
      "alignment": "left",
      "spacing_before_pt": 1,
      "spacing_after_pt": 3,
      "line_height": 1.2
    }
  },
  "spacing": {
    "paragraph_default_before_pt": 0,
    "paragraph_default_after_pt": 3,
    "default_line_height": 1.3,
    "table_cell_padding_pt": 2
  }
}
