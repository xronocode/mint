{
  "$schema": "https://mint.dev/schema/style-preset-1.0.json",
  "name": "alga_corporate",
  "version": "1.0",
  "description": "Alga Group corporate identity for documents and decks",
  "color_palette": {
    "primary":    "#0F4C81",
    "secondary":  "#5B8DBE",
    "accent":     "#FFB400",
    "text":       "#1A1A1A",
    "text_muted": "#6E6E6E",
    "background": "#FFFFFF",
    "border":     "#D4D4D4",
    "success":    "#2E7D32",
    "warning":    "#F9A825",
    "error":      "#C62828"
  },
  "typography": {
    "heading1": {
      "font": "Inter",
      "size_pt": 24,
      "color": "@primary",
      "bold": true,
      "alignment": "left",
      "spacing_before_pt": 18,
      "spacing_after_pt": 12,
      "line_height": 1.25,
      "keep_with_next": true
    },
    "heading2": {
      "font": "Inter",
      "size_pt": 18,
      "color": "@primary",
      "bold": true,
      "alignment": "left",
      "spacing_before_pt": 14,
      "spacing_after_pt": 8,
      "line_height": 1.3,
      "keep_with_next": true
    },
    "heading3": {
      "font": "Inter",
      "size_pt": 14,
      "color": "@primary",
      "bold": true,
      "alignment": "left",
      "spacing_before_pt": 10,
      "spacing_after_pt": 6,
      "line_height": 1.35,
      "keep_with_next": true
    },
    "body": {
      "font": "Inter",
      "size_pt": 11,
      "color": "@text",
      "alignment": "left",
      "spacing_before_pt": 0,
      "spacing_after_pt": 6,
      "line_height": 1.45
    },
    "table_header": {
      "font": "Inter",
      "size_pt": 11,
      "color": "@background",
      "bold": true,
      "alignment": "left",
      "spacing_before_pt": 0,
      "spacing_after_pt": 0,
      "line_height": 1.2
    },
    "caption": {
      "font": "Inter",
      "size_pt": 9,
      "color": "@text_muted",
      "italic": true,
      "alignment": "left",
      "spacing_before_pt": 2,
      "spacing_after_pt": 6,
      "line_height": 1.3
    }
  },
  "spacing": {
    "paragraph_default_before_pt": 0,
    "paragraph_default_after_pt": 6,
    "default_line_height": 1.45,
    "table_cell_padding_pt": 4
  }
}
